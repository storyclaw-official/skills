# storyclaw-skills 环境变量配置
# 复制此文件为 .env 并填入实际 API 密钥：cp env.example .env

# Giggle.pro API 密钥（giggle-drama、giggle-aimv、giggle-music、giggle-image）
# 获取地址：https://giggle.pro
GIGGLE_API_KEY=your_giggle_api_key_here

# kie.ai API 密钥（kie-nano-banana、kie-grok-imagine）
# 获取地址：https://kie.ai/api-key
KIE_API_KEY=your_kie_api_key_here
